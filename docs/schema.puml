@startuml
!theme plain
hide circle
skinparam linetype ortho
skinparam roundcorner 5
skinparam class {
    BackgroundColor White
    ArrowColor #2688d4
    BorderColor #2688d4
}

' =======================================================
' 1. IDENTITY & AUTH
' =======================================================
package "Identity_Auth" {
    entity "campuses" as campuses {
        * id : uuid <<PK>>
        --
        * short_name : string <<UK>>
        * full_name : string
        timezone : string
        is_active : boolean
        created_at : timestamp
        updated_at : timestamp
    }

    entity "coalitions" as coalitions {
        * id : smallint <<PK>>
        --
        * name : string <<UK>>
        created_at : timestamp
    }

    entity "registered_users" as registered_users {
        * student_id : string <<PK>>
        --
        created_at : timestamp
        updated_at : timestamp
    }

    entity "user_accounts" as user_accounts {
        * id : bigserial <<PK>>
        --
        student_id : string <<FK>>
        platform : string
        external_id : string
        username : string
        role : string
        is_searchable : boolean
        linked_at : timestamp
    }

    entity "user_bot_settings" as user_bot_settings {
        * id : bigserial <<PK>>
        --
        user_account_id : bigint <<FK>> <<UK>>
        language_code : string
        notifications_enabled : boolean
        created_at : timestamp
        updated_at : timestamp
    }

    entity "platform_credentials" as platform_credentials {
        * student_id : string <<PK>> <<FK>>
        --
        password_enc : bytea
        access_token : text
        updated_at : timestamp
    }

    entity "rocketchat_credentials" as rocketchat_credentials {
        * student_id : string <<PK>> <<FK>>
        --
        rc_token_enc : bytea
        updated_at : timestamp
    }

    entity "auth_verification_codes" as auth_verification_codes {
        * id : bigserial <<PK>>
        --
        student_id : string <<FK>>
        code : string
        expires_at : timestamp
        created_at : timestamp
    }
}

' =======================================================
' 2. PROJECTS & CACHE
' =======================================================
package "Projects_Cache" {
    entity "participant_stats_cache" as participant_stats_cache {
        * s21_login : string <<PK>>
        --
        campus_id : uuid <<FK>>
        coalition_id : smallint <<FK>>
        level : int
        exp_value : int
        prp : int
        crp : int
        coins : int
        updated_at : timestamp
    }

    entity "courses" as courses {
        * id : bigint <<PK>>
        --
        name : string
    }

    entity "projects" as projects {
        * id : bigint <<PK>>
        --
        course_id : bigint <<FK>>
        name : string
    }

    entity "nodes" as nodes {
        * id : bigint <<PK>>
        --
        parent_id : bigint <<FK>>
        name : string
    }

    entity "project_nodes" as project_nodes {
        * id : bigserial <<PK>>
        --
        project_id : bigint <<FK>>
        node_id : bigint <<FK>>
    }

    entity "project_search" as project_search {
        * id : bigserial <<PK>>
        --
        project_id : bigint <<FK>>
    }

    entity "review_requests" as review_requests {
        * id : bigserial <<PK>>
        --
        requester_user_id : bigint <<FK>>
        requester_campus_id : uuid <<FK>>
        negotiating_reviewer_user_id : bigint <<FK>>
        status : string
        created_at : timestamp
        updated_at : timestamp
    }
}

' =======================================================
' 3. RESOURCES
' =======================================================
package "Resources" {
    entity "rooms" as rooms {
        * id : int <<PK>>
        --
        campus_id : uuid <<FK>>
        name : string
        is_active : boolean
    }

    entity "room_bookings" as room_bookings {
        * id : bigserial <<PK>>
        --
        room_id : int <<FK>>
        campus_id : uuid <<FK>>
        user_id : bigint <<FK>>
        start_time : timestamp
        end_time : timestamp
    }

    entity "books" as books {
        * id : int <<PK>>
        --
        campus_id : uuid <<FK>>
        title : string
        author : string
    }

    entity "book_loans" as book_loans {
        * id : bigserial <<PK>>
        --
        book_id : int <<FK>>
        campus_id : uuid <<FK>>
        user_id : bigint <<FK>>
        borrowed_at : timestamp
        returned_at : timestamp
    }
}

' =======================================================
' 4. COMMUNITY & SOCIAL
' =======================================================
package "Community_Social" {
    entity "club_categories" as club_categories {
        * id : smallint <<PK>>
        --
        * name : string <<UK>>
    }

    entity "clubs" as clubs {
        * id : int <<PK>>
        --
        campus_id : uuid <<FK>>
        category_id : smallint <<FK>>
        name : string
    }

    entity "telegram_groups" as telegram_groups {
        * id : bigserial <<PK>>
        --
        name : string
    }

    entity "telegram_group_logs" as telegram_group_logs {
        * id : bigserial <<PK>>
        --
        chat_id : bigint <<FK>>
    }

    entity "telegram_group_members" as telegram_group_members {
        * id : bigserial <<PK>>
        --
        chat_id : bigint <<FK>>
        account_id : bigint <<FK>>
    }

    entity "telegram_group_settings" as telegram_group_settings {
        * chat_id : bigint <<PK>> <<FK>>
        --
        settings_payload : jsonb
    }

    entity "telegram_group_whitelists" as telegram_group_whitelists {
        * id : bigserial <<PK>>
        --
        chat_id : bigint <<FK>>
        added_by_account_id : bigint <<FK>>
    }
}

' =======================================================
' 5. SYSTEM & STATS
' =======================================================
package "System_Stats" {
    entity "fsm_user_states" as fsm_user_states {
        * id : bigserial <<PK>>
        --
        state_data : jsonb
    }

    entity "api_keys" as api_keys {
        * id : bigserial <<PK>>
        --
        user_account_id : bigint <<FK>>
        key_hash : string
        created_at : timestamp
    }

    entity "skills" as skills {
        * id : int <<PK>>
        --
        name : string <<UK>>
    }

    entity "participant_skills" as participant_skills {
        * s21_login : string <<PK>> <<FK>>
        * skill_id : int <<PK>> <<FK>>
        --
        value : int
        updated_at : timestamp
    }

    entity "schema_migrations" as schema_migrations {
        * version : string <<PK>>
    }
}

' =======================================================
' RELATIONSHIPS
' =======================================================
' --- Identity & Users ---
registered_users ||--o{ auth_verification_codes : "student_id"
registered_users ||--o| platform_credentials : "student_id"
registered_users ||--o| rocketchat_credentials : "student_id"
registered_users ||--o{ user_accounts : "student_id"

user_accounts ||--o| user_bot_settings : "user_account_id"
user_accounts ||--o{ api_keys : "user_account_id"

' --- Stats & Skills ---
participant_stats_cache ||--o{ participant_skills : "s21_login"
skills ||--o{ participant_skills : "skill_id"
campuses ||--o{ participant_stats_cache : "campus_id"
coalitions ||--o{ participant_stats_cache : "coalition_id"

' --- Education & Projects ---
courses ||--o{ projects : "course_id"
projects ||--o{ project_nodes : "project_id"
projects ||--o{ project_search : "project_id"
nodes ||--o{ nodes : "parent_id"
nodes ||--o{ project_nodes : "node_id"

' --- Resources ---
campuses ||--o{ rooms : "campus_id"
rooms ||--o{ room_bookings : "room_id"
campuses ||--o{ room_bookings : "campus_id"
user_accounts ||--o{ room_bookings : "user_id"

campuses ||--o{ books : "campus_id"
books ||--o{ book_loans : "book_id"
campuses ||--o{ book_loans : "campus_id"
user_accounts ||--o{ book_loans : "user_id"

' --- Community & Telegram ---
campuses ||--o{ clubs : "campus_id"
club_categories ||--o{ clubs : "category_id"

telegram_groups ||--o{ telegram_group_logs : "chat_id"
telegram_groups ||--o{ telegram_group_members : "chat_id"
telegram_groups ||--o| telegram_group_settings : "chat_id"
telegram_groups ||--o{ telegram_group_whitelists : "chat_id"

user_accounts ||--o{ telegram_group_members : "account_id"
user_accounts ||--o{ telegram_group_whitelists : "added_by_account_id"

' --- Reviews ---
campuses ||--o{ review_requests : "requester_campus_id"
user_accounts ||--o{ review_requests : "requester_user_id"
user_accounts ||--o{ review_requests : "negotiating_reviewer_user_id"

@enduml
