@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Компоненты bot runtime

skinparam defaultFontName Monospaced
skinparam componentStyle rectangle

ContainerDb(db, "PostgreSQL", "PostgreSQL")
System_Ext(telegram, "Telegram Bot API")
System_Ext(rocket, "Rocket.Chat API")
System_Ext(s21, "School 21 API")

Container_Boundary(bot_runtime, "Bot runtime (Go)") {
    Component(tg_transport, "Telegram transport", "gotgbot/v2", "Принимает обновления, callbacks и отправляет сообщения.")
    Component(fsm_engine, "FSM engine", "Flow parser + state store", "Загружает YAML flows, восстанавливает state и маршрутизирует actions.")
    Component(action_modules, "Action-модули", "registration / booking / library / reviews / stats / settings / groups / clubs", "Пользовательские сценарии бота.")
    Component(user_service, "Сервис пользователей", "Go service", "Профили, user accounts, platform links.")
    Component(otp_service, "OTP service", "Go service", "Генерация OTP, rate limit и доставка через Rocket.Chat.")
    Component(credential_service, "Сервис credentials", "Go service + AES-GCM", "Зашифрованные School 21 credentials и tokens.")
    Component(schedule_regen, "Регенерация расписаний", "Go service + imgcache", "Строит schedule PNG и инвалидирует Telegram file IDs.")
    Component(repo, "Репозитории", "sqlc + pgx", "Слой доступа к БД.")
}

Rel(telegram, tg_transport, "Обновления")
Rel(tg_transport, fsm_engine, "Передает события")
Rel(fsm_engine, action_modules, "Вызывает actions")

Rel(action_modules, user_service, "Профили и связи")
Rel(action_modules, otp_service, "OTP flow регистрации")
Rel(action_modules, credential_service, "School 21 auth и verify")
Rel(action_modules, schedule_regen, "Force regenerate после booking changes")
Rel(action_modules, repo, "Читает и пишет доменные данные")

Rel(otp_service, rocket, "chat.postMessage / users.info", "HTTPS/REST")
Rel(credential_service, s21, "Auth / participant API", "HTTPS/REST")
Rel(schedule_regen, tg_transport, "Invalidate cached file_id")
Rel(user_service, repo, "CRUD")
Rel(repo, db, "SQL")
Rel(tg_transport, telegram, "SendMessage / SendPhoto")

@enduml
