@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Компоненты HTTP API

Person_Ext(integrator, "Внешняя интеграция", "Вызывает endpoint регистрации вебхука.")
ContainerDb(db, "PostgreSQL", "PostgreSQL")

Container_Boundary(api_runtime, "HTTP server (внутри Go-приложения)") {
    Component(server, "HTTP server", "net/http + ServeMux", "Поднимает HTTP listener и маршрутизирует запросы.")
    Component(handler, "Webhook handler", "net/http handler", "Обрабатывает POST /api/v1/webhook/register.")
    Component(api_keys, "Сервис API-ключей", "Go service", "Валидирует X-Secret по хэшу ключа.")
    Component(repo, "Репозитории", "sqlc + pgx", "Читает api_keys и user_accounts.")
}

Rel(integrator, server, "POST /api/v1/webhook/register", "HTTP/JSON")
Rel(server, handler, "Маршрутизация")
Rel(handler, api_keys, "ValidateApiKey(X-Secret)")
Rel(handler, repo, "GetUserAccountByExternalId")
Rel(api_keys, repo, "GetApiKeyByHash")
Rel(repo, db, "SQL SELECT")

@enduml
