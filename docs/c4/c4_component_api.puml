@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component diagram for HTTP API

Person_Ext(integrator, "External Integrator", "Вызывает endpoint регистрации вебхука.")
ContainerDb(db, "PostgreSQL", "PostgreSQL")

Container_Boundary(api_runtime, "HTTP Server (inside Go app)") {
    Component(server, "HTTP Server", "net/http + ServeMux", "Поднимает HTTP listener и маршрутизирует запросы.")
    Component(handler, "Register Webhook Handler", "net/http handler", "Обрабатывает POST /api/v1/webhook/register.")
    Component(api_keys, "API Key Service", "Go service", "Валидирует X-Secret по хэшу ключа.")
    Component(repo, "Repositories", "sqlc + pgx", "Читает api_keys и user_accounts.")
}

Rel(integrator, server, "POST /api/v1/webhook/register", "HTTP/JSON")
Rel(server, handler, "Route request")
Rel(handler, api_keys, "ValidateApiKey(X-Secret)")
Rel(handler, repo, "GetUserAccountByExternalId")
Rel(api_keys, repo, "GetApiKeyByHash")
Rel(repo, db, "SQL SELECT")

@enduml
