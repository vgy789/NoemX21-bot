@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component diagram for Sync Worker (Go)

ContainerDb(db, "Database", "PostgreSQL", "Хранит токены кампусов и кэш ивентов/сейлов.")
System_Ext(s21, "School 21 API", "Официальный источник данных.")

Container_Boundary(sync_worker, "Sync Worker") {
    Component(scheduler, "Task Scheduler", "Go: gocron / Ticker", "Запускает задачи по расписанию (раз в 15-60 минут).")
    
    Component(token_mgr, "Token Manager", "Go Logic", "Выбирает живой токен Data Provider'а для нужного кампуса.")
    
    Component(sync_logic, "Sync Engine", "Go Logic", "Цикл: Опрос API -> Сравнение данных -> Обновление кэша.")
    
    Component(s21_client, "S21 Client", "Go: HTTP Client", "Обертка над API школы с обработкой ошибок и лимитов.")
    
    Component(repo, "Data Repository", "Go: pgx", "Обновляет таблицы ивентов, сейлов и статистики.")
}

Rel_D(scheduler, sync_logic, "Инициирует запуск")
Rel(sync_logic, token_mgr, "Запрашивает токен для кампуса")
Rel(token_mgr, repo, "Читает токены из БД")
Rel(sync_logic, s21_client, "Запрос данных (Events/Sales)")
Rel(s21_client, s21, "HTTPS Request", "REST")
Rel(sync_logic, repo, "Записывает свежие данные в кэш")
Rel(repo, db, "SQL INSERT/UPDATE", "TCP/5432")

@enduml
