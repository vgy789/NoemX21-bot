@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Компоненты фоновых задач

skinparam defaultFontName Monospaced
skinparam componentStyle rectangle

ContainerDb(db, "PostgreSQL", "PostgreSQL")
System_Ext(s21, "School 21 API")
System_Ext(git_repo, "Git-репозиторий контента")
Container(fs, "Локальная файловая система", "Disk", "Git checkout и временные schedule PNG.")

Container_Boundary(background_runtime, "Фоновые сервисы (внутри Go-приложения)") {
    Component(app_runner, "App runner", "errgroup", "Запускает фоновые сервисы вместе с Telegram и HTTP transport.")
    Component(gitsync, "GitSync service", "cron + go-git", "Обновляет git-репозиторий и синхронизирует YAML-контент в БД.")
    Component(campus, "Сервис кампусов", "cron", "Обновляет кампусы и закрывает устаревшие review requests.")
    Component(schedule_gen, "Генератор расписаний", "ticker + imgcache", "Строит schedule PNG для активных кампусов.")
    Component(credentials, "Сервис credentials", "Go service + AES-GCM", "Выдает валидные School 21 access tokens.")
    Component(repo, "Репозитории", "sqlc + pgx", "Доступ к данным кампусов, bookings, reviews и catalogs.")
}

Rel(app_runner, gitsync, "Запуск")
Rel(app_runner, campus, "Запуск")
Rel(app_runner, schedule_gen, "Запуск")

Rel(gitsync, git_repo, "Clone / fetch", "SSH git")
Rel(gitsync, fs, "Читает локальный checkout")
Rel(gitsync, repo, "Upsert каталога и campus content")

Rel(campus, credentials, "GetValidToken")
Rel(campus, s21, "GetCampuses / GetParticipantProjects", "HTTPS/REST")
Rel(campus, repo, "Upsert кампусов и закрытие stale reviews")

Rel(schedule_gen, repo, "Читает кампусы, комнаты и bookings")
Rel(schedule_gen, fs, "Пишет PNG files")

Rel(repo, db, "SQL")

@enduml
