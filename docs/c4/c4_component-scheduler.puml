@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component diagram for Background Jobs

skinparam defaultFontName Monospaced
skinparam componentStyle rectangle

ContainerDb(db, "PostgreSQL", "PostgreSQL")
System_Ext(s21, "School 21 API")
System_Ext(git_repo, "Content Git Repository")
Container(fs, "Local Filesystem", "Disk", "Git checkout and temporary schedule PNG files.")

Container_Boundary(background_runtime, "Background Services (inside Go app)") {
    Component(app_runner, "App Runner", "errgroup", "Starts background services with Telegram and HTTP transports.")
    Component(gitsync, "GitSync Service", "cron + go-git", "Updates the git repo and syncs YAML content into the database.")
    Component(campus, "Campus Service", "cron", "Refreshes campuses and closes stale review requests.")
    Component(schedule_gen, "Schedule Image Generator", "ticker + imgcache", "Builds schedule PNGs for active campuses.")
    Component(credentials, "Credential Service", "Go service + AES-GCM", "Provides valid School 21 access tokens.")
    Component(repo, "Repositories", "sqlc + pgx", "Data access for campuses, bookings, reviews, and catalogs.")
}

Rel(app_runner, gitsync, "Start")
Rel(app_runner, campus, "Start")
Rel(app_runner, schedule_gen, "Start")

Rel(gitsync, git_repo, "Clone / fetch", "SSH git")
Rel(gitsync, fs, "Reads local checkout")
Rel(gitsync, repo, "Upserts catalog and campus content")

Rel(campus, credentials, "GetValidToken")
Rel(campus, s21, "GetCampuses / GetParticipantProjects", "HTTPS/REST")
Rel(campus, repo, "Upserts campuses and closes stale reviews")

Rel(schedule_gen, repo, "Reads campuses, rooms, bookings")
Rel(schedule_gen, fs, "Writes PNG files")

Rel(repo, db, "SQL")

@enduml
