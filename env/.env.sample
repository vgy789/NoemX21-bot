PRODUCTION=false

# Database Configuration
DATABASE_URL=postgres://user:pass@localhost:5432/noemx21?sslmode=disable&timezone=UTC
AEAD_KEY=

# Rocket.Chat Configuration
ROCKETCHAT_API_URL=
ROCKETCHAT_USER_ID=
ROCKETCHAT_AUTH_TOKEN=

# School21 Configuration
SCHOOL21_API_URL=
SCHOOL21_USER_LOGIN=
SCHOOL21_USER_PASSWORD=

# Telegram Configuration
TELEGRAM_BOT_TOKEN=
# Custom Telegram Bot API URL (optional - for local bot API servers like https://github.com/tdorgachev/telegram-bot-api)
# Leave empty to use official Telegram API (https://api.telegram.org)
TELEGRAM_API_URL=

# Telegram Webhook Configuration (optional - for webhook mode)
TELEGRAM_WEBHOOK_ENABLED=false
# Full webhook URL that Telegram will call (required for webhook mode)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook
# Path to listen for webhook requests (default: /telegram/webhook)
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# Port for webhook server (default: 8080, can use same as API server)
TELEGRAM_WEBHOOK_PORT=8080
# Optional secret token for webhook verification (Telegram sends X-Telegram-Bot-Api-Secret-Token header)
TELEGRAM_WEBHOOK_SECRET=

# Charts (temporary files directory)
CHART_TEMP_DIR=tmp

# Git Repository For Data
GIT_REPO_URL=git@git.company.com:2222/user/repo.git
GIT_BRANCH=main
GIT_SYNC_INTERVAL=5m
GIT_LOCAL_PATH=data_repo
SSH_KEY_BASE64=
SSH_KNOWN_HOSTS=
